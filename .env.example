# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# .env.example = safe template (committed to git)
# .env           = your real secrets (NEVER commit — already in .gitignore)

# Server + client (Vite exposes VITE_* to the browser)
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_SUPABASE_PROJECT_ID"

# AI (server-only — never prefix with VITE_)
# Comma-separate multiple keys per provider for automatic rotation on rate limits.
GEMINI_API_KEY="YOUR_GEMINI_KEY_1,YOUR_GEMINI_KEY_2"
GROQ_API_KEY="YOUR_GROQ_KEY_1,YOUR_GROQ_KEY_2"
# Prefer Groq for text (saves Gemini quota). Set to "false" to try Gemini first.
AI_PREFER_GROQ="true"

# Optional: admin-only server operations
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
